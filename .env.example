# Copy this file to `.env` and fill in the values.
# `.env` is in `.gitignore` — NEVER commit it.
#
# The CI workflow reads these values from GitHub Secrets instead
# of `.env` — this file exists so local runs (Terraform from your
# laptop, manual phase scripts) can use the same variable names.

# DigitalOcean API token with full access.
# Scope: droplet:create/delete/read, ssh_key:read, domain:read (optional).
# Rotate this token the moment you suspect exposure.
DIGITALOCEAN_TOKEN=

# The SSH key fingerprint registered with DO. Find with:
#   doctl compute ssh-key list
DIGITALOCEAN_SSH_KEY_FINGERPRINT=

# Path to the matching private key on your local machine.
SSH_PRIVATE_KEY=~/.ssh/id_ed25519

# Region for all campaign droplets.
DIGITALOCEAN_REGION=nyc3

# The git ref of ai-memory-mcp that this campaign is validating.
# Accepts tag, branch, or full SHA. Cloud-init will `git clone` +
# `git checkout` this exact ref.
AI_MEMORY_GIT_REF=release/v0.6.0

# Campaign identifier — shows up in run directory + report titles.
CAMPAIGN_ID=v0.6.0.0-candidate

# Kill-switch: droplets self-destroy after this many hours of
# uptime even if the workflow is still running. Hard cost ceiling.
DEAD_MAN_SWITCH_HOURS=8
